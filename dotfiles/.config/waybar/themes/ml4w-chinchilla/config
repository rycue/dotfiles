{
    "layer": "top",
    "margin-top": 10,
    "margin-bottom": -5,
    "margin-left": 0,
    "margin-right": 5,    
    "spacing": 0,

    "include": [
        "~/.config/ml4w/settings/waybar-quicklinks.json"
