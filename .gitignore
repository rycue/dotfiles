# ──────────────────────────────────────────────────────────
# 1. Ignore EVERYTHING by default
*
# ──────────────────────────────────────────────────────────
# 2. Do not ignore .gitignore itself
!.gitignore
# ──────────────────────────────────────────────────────────
# 3. Whitelist only the .config folder and its entire contents
!.config/
!.config/**
!.config/hypr/
!.config/Hyprland/
# ──────────────────────────────────────────────────────────
# 4. Optionally, whitelist additional dotfiles if needed
# Uncomment these lines if you want to track these files outside .config
!.bashrc
!.bash_profile
!.zshrc
!.zshrc_custom
!.p10k.zsh
!.gitconfig
!.Xresources
!.xinitrc


# Large programs
.config/Code/
.config/VSCodium/
.config/vivaldi/
.config/Hyprlock-Styles/
.config/hyde/
.config/Hyprland/build/

# Backups & logs
.config/cfg_backups/
.config/hypr_new_backup/
.config/obsidian/
.config/ml4w/
.config/pulse.bak/
.config/ags/
.config/Hyprland/subprojects/
.config/Hyprland/src/

# Caches
.config/librewolf/
.config/mozilla/
.config/gtk-3.0/
.config/dconf/
.config/qutebrowser/
.config/KDE/
.config/systemd/
