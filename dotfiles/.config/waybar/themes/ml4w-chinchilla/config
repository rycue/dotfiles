    "pulseaudio": {
        "scroll-step": 1,
        "format": "{icon}{volume:>3}%",
        "format-bluetooth": "{icon}{volume}%",
        "format-muted": "пА¶√Ч",
        "format-icons": {
            "headphones": "пА•",
            "handsfree": "пА•",
            "headset": "пА•вАЙвАЙвАЙ",
            "phone": "пВХ",
            "portable": "пВХ",
            "car": "пЖє",
            "default": ["пА®"]
