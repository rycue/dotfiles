# Ignore everything by default
*

# Except this file
!.gitignore

# Allow specific config files
!.bashrc
!.bash_profile
!.zshrc
!.zshrc_custom
!.gitconfig
!.vimrc
!.p10k.zsh

# Allow specific config directories (tweak these to your needs)
!.config/
!.config/nvim/
!.config/kitty/
!.config/hypr/

# Ignore personal/sensitive or auto-generated files and directories
.bash_history
.zsh_history
.ssh/
.gnupg/
.cache/
.local/
.npm/
.vscode/
