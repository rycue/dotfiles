    "hyprland/workspaces": {  
        "disable-scroll": true,
        "all-outputs": true,
	    "sort-by-number": true,
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "1": "дЄА",
            "2": "дЇМ",
            "3": "дЄЙ",
            "4": "еЫЫ",
            "5": "дЇФ",
            "6": "еЕ≠",
            "7": "дЄГ",
            "8": "еЕЂ",
            "9": "дєЭ",
            "10": "еНБ",
            "active": "пБЃ",
            "urgent": "пБ™"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
          }
    },

    "mpd": {
        "tooltip": true,
        "tooltip-format": "{artist} - {album} - {title} - Total Time : {totalTime:%M:%S}",
        "format": "пЛ≤ {elapsedTime:%M:%S}",
        "format-disconnected": "вЪ†  Disconnected",
        "format-stopped": "пЛ≤ Not Playing",
        "on-click": "mpc toggle",
        "state-icons": {
        "playing": "пБЛ",
        "paused": "п££"
        }
    },
    "mpd#2": {
        "format": "пБИ",
        "format-disconnected": "пБИ",
        "format-paused": "пБИ",
        "format-stopped": "пБИ",
        // Commands to execute on events
        "on-click": "mpc -q pause && mpc -q prev && mpc -q start"
    },
    "mpd#3": {
        "interval": 1,
        "format": "{stateIcon}",
        "format-disconnected": "пБЛ",
        "format-paused": "{stateIcon}",
        "format-stopped": "пБЛ",
        "state-icons": {
        "paused": "пБЛ",
        "playing": "пБМ"
        },
        // Commands to execute on events
        "on-click": "mpc toggle"
    },
    "mpd#4": {
        "format": "пБС",
        "format-disconnected": "пБС",
        "format-paused": "пБС",
        "format-stopped": "пБС",
        // Commands to execute on events
        "on-click": "mpc -q pause && mpc -q next && mpc -q start"
    },
    "hyprland/window": {
        "rewrite": {
            ".* - (.*?)$": "$1",
            ".* вАФ (.*?)": "$1",
            "(.*) Microsoft Teams": "$1"
        },
        "icon": true,
        "icon-size": 32,
        "separate-outputs": true
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "пЖЕDEF",
            "performance": "йЂШжАІиГљ",
            "balanced": "гГРгГ©гГ≥гВє",
            "power-saver": "зЬБйЫїеКЫ"
        }
    },
    "custom/swap": {
        "on-click": "~/.config/waybar/scripts/swap.sh",
        "tooltip": "Swap between waybar configs",
        "format": "Bg пИД "
    },
    "custom/mpd": {
        "format": "пАБ {title} - {artist}",
        "interval": 5,
        "exec": "mpc current --format='\"title\":\"%title%\",\"artist\":\"%artist%\"'"
    },
    "custom/cava-internal": {
        "exec": "sh ~/.config/waybar/scripts/Cava.sh",
        "format": "{}",
        "tooltip": false,
        "on-click": "swaymsg reload & pkill waybar & waybar",
        "layer": "below",
        "output": "all"
    },
    "custom/notification": {
        "tooltip-format": "Left: Notifications\nRight: Do not disturb",
        "format": "{icon}",
        "format-icons": {
            "notification": "пВҐ<sup>пСД</sup>",
            "none": "пВҐ",
            "dnd-notification": "пЗЈвАЙ<sup>пСД</sup>",
            "dnd-none": "пЗЈ",
            "inhibited-notification": "пВҐ<sup>пСД</sup>",
            "inhibited-none": "пВҐ",
            "dnd-inhibited-notification": "пЗЈвАЙ<sup>пСД</sup>",
            "dnd-inhibited-none": "пЗЈ"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "custom/pacman": {
        "format": "пЖ≤ {}",
        "escape": true,
        "exec": "i=$(checkupdates); echo \"$i\" |wc -l; echo \"$i\" |column -t |tr '\n' '\r'", // # of updates and tooltip details
        "exec-if": "exit 0", // always run; consider advanced run conditions
        // "exec": "~/.config/ml4w/scripts/updates.sh",
        // "return-type": "json",
        "interval": 1800,
        "on-click": "kitty -e sudo pacman -Syu", // update system
        "on-click-right": "~/.config/ml4w/settings/software.sh",
        "signal": 8
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
        "activated": "пБЃ",
        "deactivated": "пБ∞"
        }
    },
    "custom/ml4w-welcome": {
        "on-click": "flatpak run com.ml4w.sidebar",
        "tooltip-format": "Open ML4W Sidebar App",
        "format": "пВЕ вАЙML4W",
