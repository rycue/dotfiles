    "modules-left": [
        "hyprland/workspaces",
        "custom/empty",
        "custom/empty",
        "custom/empty",
        "bluetooth",
        "pulseaudio",
        "network",
        "custom/fullscreen"
    ],
    
    "modules-center": [
        "hyprland/window"
    ],
    
    "modules-right": [
        "custom/language", "custom/fcitx5",
        "custom/pacman",
        "temperature",
        "power-profiles-daemon",
        // "group/tools",
        "custom/tray",
        // "custom/exit",
